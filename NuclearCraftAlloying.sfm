-- Steel Production using Akashic Tome --

        Input 256
            minecraft:redstone_block
            From EMCLink

        Input 256
            thermalfoundation:material@160
            From Drawers

        Output Retain 128
            minecraft:redstone_block
            To Steel

        Output Retain 256
            thermalfoundation:material@160
            To Steel

Forget

-- Dark Steel Ingot --

        Input 16
            minecraft:obsidian
            From EMCLink

        Input 16
            thermalfoundation:material@160
            From Drawers

        Output Retain 16
            minecraft:obsidian
            To DarkSteel Slot 0

        Output Retain 16
            thermalfoundation:material@160
            To DarkSteel Slot 1
    
Forget

-- Electrical Steel Ingot --

        Input 8
            appliedenergistics2:material@5
            From EMCLink

        Input 8
            thermalfoundation:material@160
            From Drawers

        Output Retain 8
            appliedenergistics2:material@5
            To ElectricalSteel Slot 0
        
        Output Retain 8
            thermalfoundation:material@160
            To ElectricalSteel Slot 1

End

Every 80 Ticks Do

-- Dimensional Blend --

    If Drawers Has 
            > 128 thermalfoundation:material@770 Then

        Input 8
            techreborn:dust@21
            From EMCLink

        Input 32
            thermalfoundation:material@770
            From Drawers

        Output Retain 8
            techreborn:dust@21
            To DimBlend Slot 0
        
        Output Retain 32
            thermalfoundation:material@770
            To DimBlend Slot 1
    
    End

-- End Steel Ingot --

    If Drawers Has 
            > 128 enderio:item_alloy_ingot@6 Then

        Input 8
            enderio:item_alloy_ingot@6
            From Drawers

        Input 16
            nuclearcraft:compound@8
            From Drawers

        Output Retain 8
            enderio:item_alloy_ingot@6
            To EndSteel Slot 0

        Output Retain 16
            nuclearcraft:compound@8
            To EndSteel Slot 1
    
    End 

-- Vivid Alloy Ingot --

    If Drawers has > 256 enderio:item_alloy_endergy_ingot@5 Then

    Input 8
        minecraft:ender_pearl
        From EMCLink
    Input 8
        enderio:item_alloy_endergy_ingot@5
        From Drawers

    Output Retain 8
        minecraft:ender_pearl
        To VividAlloy Slot 0
    Output Retain 8
        enderio:item_alloy_endergy_ingot@5
        To VividAlloy Slot 1

    End

-- Vibrant Alloy Ingot --

    If Drawers has > 256 enderio:item_alloy_ingot@1 Then

    Input 8
        enderio:item_alloy_ingot@1
        From Drawers
    Input 8
        minecraft:ender_pearl
        From EMCLink

    Output Retain 8
        enderio:item_alloy_ingot@1
        To VibrantAlloy Slot 0
    Output Retain 8
        minecraft:ender_pearl
        To VibrantAlloy Slot 1

    End

-- Melodic Alloy --

    If Drawers Has 
            > 128 enderio:item_alloy_ingot@8 Then

        Input 8
            enderio:item_alloy_ingot@8
            From Drawers

        Input 16
            minecraft:chorus_fruit_popped
            From EMCLink

        Output Retain 8
            enderio:item_alloy_ingot@8
            To MelAlloy Slot 0

        Output Retain 16
            minecraft:chorus_fruit_popped
            To MelAlloy Slot 1
    
    End 

End